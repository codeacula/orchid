# =============================================================================
# Caddy Configuration for Orchid MVP
# Routes API requests to backend, serves SPA from frontend
# =============================================================================

:80 {
    # API Routes — Reverse proxy to backend service
    handle /api/* {
        reverse_proxy backend:3000 {
            # WebSocket support (automatic in Caddy 2)
            header_up Connection "upgrade"
            header_up Upgrade "websocket"
        }
    }

    # WebSocket chat transport
    handle /ws {
        reverse_proxy backend:3000
    }

    # Health check endpoint
    handle /health {
        respond "OK" 200
    }

    # Frontend application
    # Historical SPA note: a static setup would use try_files + file_server here.
    handle {
        reverse_proxy frontend:5173
    }
}
