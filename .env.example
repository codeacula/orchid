# =============================================================================
# Environment Configuration Example
# Copy this to .env and fill in your values
# =============================================================================

# Database
DATABASE_URL=postgres://orchid:orchid@localhost:5432/orchid

# Cache
REDIS_URL=redis://localhost:6379

# Session Management
SESSION_SECRET=change-me-in-production-use-a-long-random-string

# Owner Account
OWNER_USERNAME=admin
OWNER_PASSWORD=change-me

# System Prompts
OWNER_SYSTEM_PROMPT=You are a helpful assistant for the system owner.
USER_SYSTEM_PROMPT=You are a helpful assistant.

# AI Provider Configuration
AI_PROVIDER=openai
AI_API_KEY=your-api-key-here
AI_MODEL=gpt-4o

# Application Ports
BACKEND_PORT=3000
FRONTEND_PORT=5173
CADDY_PORT=80
